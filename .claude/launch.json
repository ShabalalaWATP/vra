{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vragent-backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000,
      "cwd": "vragent/backend"
    },
    {
      "name": "vragent-frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "3000"],
      "port": 3000,
      "cwd": "vragent/frontend"
    }
  ]
}
